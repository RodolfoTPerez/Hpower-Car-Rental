    const resV = await syncVehicles(vehRes.data || []);

    const ratesRes = await fetch(HQ_API_RATES_URL, { headers: HQ_HEADERS }).then(r => r.json());
    const ratesData = Array.isArray(ratesRes) ? ratesRes : (ratesRes.data || []);
