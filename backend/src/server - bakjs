app.get('/api/sync/all', async (req, res) => {
  try {
    console.log("\n🚀 INICIANDO SINCRONIZACIÓN TOTAL");
    const locRes = await fetch(HQ_API_LOCATIONS_URL, { headers: HQ_HEADERS }).then(r => r.json());
